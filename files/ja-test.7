.  br
.  ds cev \n[.ev]
.  di @\\$0
.  ev @\\$0
.  evc \\*[cev]
.  in 0
.  nop \\$1
.  nop \\$2
.  br
.  ev
.  di
.  nr wd \\n[dl]
.  IP \(bu 3
