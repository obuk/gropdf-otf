.    ie (\\n[wd] = \\n[ws]) .nop ok (スペースが削除された)
.    el .nop not ok (スペースが削除されなかった)
.  \}
.  el \{\
.    nop :
.    ie (\\n[wd] = \\n[wk]) .nop ok (スペースが削除され、カーニングされた)
.    el .nop not ok (スペースが削除されなかった)
.  \}
